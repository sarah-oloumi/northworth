{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Northworth",
  "version": "0.1.0",
  "identifier": "com.saraholoumi.northworth",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Northworth",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self'; img-src 'self' asset: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
